# =============================================================================
# NexCart — Required Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to version control.
# =============================================================================

# ─── Database (required) ──────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/nexcart?schema=public"
# Optional: direct URL for migrations (bypasses connection pooling on Vercel)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/nexcart?schema=public"

# ─── Auth.js v5 (required) ────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="your-32-char-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Google OAuth (optional — remove to disable) ──────────────────────────────
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Payments ─────────────────────────────────────────────────────────────────
# Stripe (international)
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# eSewa (Nepal) — sandbox: https://rc-epay.esewa.com.np
ESEWA_MERCHANT_ID=""
ESEWA_BASE_URL="https://rc-epay.esewa.com.np"

# Khalti (Nepal) — sandbox: https://dev.khalti.com
KHALTI_SECRET_KEY=""
KHALTI_BASE_URL="https://dev.khalti.com"

# ─── Storage (product + avatar images) — Cloudinary required ─────────────────
# Sign up free at https://cloudinary.com → Dashboard → API Keys
# Free tier: 25 GB storage, 25 GB bandwidth/month — enough for production
CLOUDINARY_CLOUD_NAME=""   # e.g. "myshop"
CLOUDINARY_API_KEY=""      # numeric key from Cloudinary dashboard
CLOUDINARY_API_SECRET=""   # secret from Cloudinary dashboard
#
# Images are stored under:
#   nexcart/products/  — admin product uploads (max 5 MB, auto-optimised to 1600px)
#   nexcart/avatars/   — customer profile photos (max 2 MB, cropped to 400px)

# ─── Email (optional) ─────────────────────────────────────────────────────────
# One of: resend | sendgrid | smtp (leave blank to skip email sending)
EMAIL_PROVIDER=""
EMAIL_FROM="noreply@nexcart.com"
RESEND_API_KEY=""
SENDGRID_API_KEY=""
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# ─── Rate Limiting (optional — falls back to in-memory if blank) ──────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Security ─────────────────────────────────────────────────────────────────
# argon2 = native (fastest) | bcryptjs = pure JS (no native build needed)
PASSWORD_HASH_ALGORITHM="bcryptjs"
PASSWORD_RESET_EXPIRY_HOURS="2"
SESSION_MAX_AGE_DAYS="30"

# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_CURRENCY="NPR"
NEXT_PUBLIC_CURRENCY_SYMBOL="Rs."
NEXT_PUBLIC_DEFAULT_LOCALE="en-NP"

# ─── Admin Seed ───────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@nexcart.com"
ADMIN_PASSWORD="ChangeMe123!"
