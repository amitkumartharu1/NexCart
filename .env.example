# =============================================================================
# NexCart — Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
# Supabase:  postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# Neon:      postgresql://[USER]:[PASSWORD]@[HOST]/[DB]?sslmode=require
# Local:     postgresql://postgres:password@localhost:5432/nexcart
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/nexcart"

# Used by Prisma for connection pooling (Supabase / PgBouncer)
# If not using pooling, set same as DATABASE_URL
DIRECT_URL="postgresql://postgres:password@localhost:5432/nexcart"

# -----------------------------------------------------------------------------
# NEXT AUTH (Auth.js v5)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here-generate-with-openssl-rand-base64-32"

# Base URL of your application
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# OAUTH PROVIDERS (optional — leave blank to disable)
# -----------------------------------------------------------------------------
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# -----------------------------------------------------------------------------
# STRIPE (Payments)
# -----------------------------------------------------------------------------
# Publishable key (safe to expose to client)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Secret key (server only — never expose to client)
STRIPE_SECRET_KEY="sk_test_..."

# Webhook signing secret (from Stripe dashboard or CLI)
STRIPE_WEBHOOK_SECRET="whsec_..."

# -----------------------------------------------------------------------------
# FILE STORAGE
# Provider: "cloudinary" | "s3" | "local"
# -----------------------------------------------------------------------------
STORAGE_PROVIDER="cloudinary"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_PRESET="nexcart_unsigned"

# AWS S3 (alternative)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""
AWS_S3_ENDPOINT=""

# -----------------------------------------------------------------------------
# RATE LIMITING (Upstash Redis — optional)
# Leave blank to use in-memory fallback (not suitable for production clusters)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# APP CONFIGURATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="NexCart"
NEXT_PUBLIC_APP_DESCRIPTION="Smart Shopping. Modern Services. One Premium Platform."

# Currency
NEXT_PUBLIC_CURRENCY="USD"
NEXT_PUBLIC_CURRENCY_SYMBOL="$"

# Default locale
NEXT_PUBLIC_DEFAULT_LOCALE="en-US"

# -----------------------------------------------------------------------------
# EMAIL (Transactional)
# Provider: "resend" | "sendgrid" | "smtp" | "nodemailer"
# -----------------------------------------------------------------------------
EMAIL_PROVIDER="resend"

# Resend
RESEND_API_KEY=""

# SMTP fallback
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@nexcart.com"

# -----------------------------------------------------------------------------
# ADMIN
# -----------------------------------------------------------------------------
# Seed admin email (used by prisma/seed.ts only)
SEED_ADMIN_EMAIL="admin@nexcart.com"
SEED_ADMIN_PASSWORD="ChangeThisImmediately#2024"

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# Argon2 or bcrypt — "argon2" recommended for production
PASSWORD_HASH_ALGORITHM="argon2"

# How many days before password reset token expires
PASSWORD_RESET_EXPIRY_HOURS="2"

# How many days JWT sessions last
SESSION_MAX_AGE_DAYS="30"

# -----------------------------------------------------------------------------
# NODE
# -----------------------------------------------------------------------------
NODE_ENV="development"
